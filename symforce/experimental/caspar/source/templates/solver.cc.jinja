            {% endif %}
          {% endif %}
        {% endfor %}
        {{solver_key("res_tot")}},
        {{num_key(fac)}}
    );
    {% endfor %}
    return 0.5 * ReadCuMem({{solver_key("res_tot")}});
}

void {{ solver.struct_name }}::DoBeta() {
    Zero({{solver_key("beta_numerator")}}, {{solver_key("beta_numerator")}}+1);
